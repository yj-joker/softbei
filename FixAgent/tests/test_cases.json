{
  "test_cases": [
    {
      "id": "bom_transmission_shaft",
      "query": "传动主副轴装配部件清单",
      "top_k": 10,
      "category": "recall",
      "checks": {
        "min_results": 1,
        "must_have_chunk_types": ["table"],
        "must_have_chunk_types_min_images": 1,
        "must_contain_any": ["主轴", "副轴", "传动"],
        "must_not_contain": ["知识库中未提取到", "未检索到"]
      }
    },
    {
      "id": "bom_transmission_shaft_images",
      "query": "传动主副轴装配部件清单",
      "top_k": 10,
      "category": "recall",
