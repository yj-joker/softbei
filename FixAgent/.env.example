# 阿里云百炼 API
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY   # sk-xxxx
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.7 # 温度参数
LLM_TOP_P=0.9 # top_p 参数

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=86400

# Neo4j图数据库配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD
NEO4J_DATABASE=neo4j

# RAG文件存储 - 本机 MinIO
FILE_STORAGE_BACKEND=minio
FILE_PUBLIC_BASE_URL=/files
LOCAL_FILE_STORAGE_DIR=rag_files
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_DOCUMENT_BUCKET=weixiu-private-wendang
MINIO_PUBLIC_IMAGE_BUCKET=weixiu-public-tupian
MINIO_PUBLIC_BASE_URL=http://localhost:9000/weixiu-public-tupian
MINIO_SECURE=false

# 图片语义摘要，确认多模态 LLM 可用后改为 true
IMAGE_SUMMARY_LLM_ENABLED=true

# MySQL（与 Java 端共用的 fix 库，用于知识库盘点等结构化查询）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=fix
MYSQL_USER=root
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD
